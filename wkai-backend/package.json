    "dotenv":                  "^16.4.5",
    "express":                 "^4.21.0",
    "firebase-admin":          "^12.7.0",
    "helmet":                  "^8.0.0",
    "morgan":                  "^1.10.0",
    "multer":                  "^1.4.5-lts.1",
    "pg":                      "^8.13.0",
