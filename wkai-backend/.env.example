# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://wkai:wkai_password@localhost:5432/wkai

# ─── Redis (used for: session state, student counts, transcript cache, LangChain memory)
REDIS_URL=redis://localhost:6379

# ─── Groq — ALL AI runs here (Vision, Text, Whisper) ─────────────────────────
# Free tier at https://console.groq.com — no credit card needed
# Powers:
#   LangGraph screen pipeline → Llama-4 Scout (vision)
#   LangGraph error agent     → Llama3-70b (text)
#   LangGraph intent agent    → Llama3-70b (text)
#   Whisper transcription     → whisper-large-v3
GROQ_API_KEY=gsk_...

# ─── Firebase Storage (optional — for file sharing) ──────────────────────────
FIREBASE_PROJECT_ID=wkai-app
FIREBASE_STORAGE_BUCKET=wkai-app.appspot.com
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ─── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
